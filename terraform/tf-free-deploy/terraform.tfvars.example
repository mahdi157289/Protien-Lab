# ==============================================================================
# terraform.tfvars.example
# ------------------------------------------------------------------------------
# ██████████████████████████████████████████████████████████████████████████████
# ██                                                                          ██
# ██   IDE INSTRUCTIONS — READ THIS FIRST                                    ██
# ██                                                                          ██
# ██   1. Rename this file to:  terraform.tfvars                             ██
# ██   2. Replace EVERY <PLACEHOLDER> with real values from the project      ██
# ██   3. Fill app_env_vars with ALL env vars the app needs to run           ██
# ██   4. Never commit terraform.tfvars to git (it's in .gitignore)          ██
# ██   5. Run: terraform init → terraform plan → terraform apply             ██
# ██                                                                          ██
# ██████████████████████████████████████████████████████████████████████████████
# ==============================================================================


# ── SECTION 1: Project Identity ───────────────────────────────────────────────

project_name = "<YOUR_PROJECT_SLUG>"    # e.g. "proteinlab" — lowercase, no spaces
environment  = "production"             # production | staging | dev
owner        = "<YOUR_NAME>"            # e.g. "mahdi"


# ── SECTION 2: AWS ────────────────────────────────────────────────────────────

aws_region = "us-east-1"               # free tier region — don't change unless needed


# ── SECTION 3: Your Application ───────────────────────────────────────────────

# Your Docker image — the app to deploy
# IDE: replace with the project's actual Docker Hub image
docker_image = "<DOCKERHUB_USER>/<IMAGE_NAME>:<TAG>"
# Examples:
#   "mahdi157/proteinlab:latest"
#   "nginx:alpine"
#   "node:20-alpine"  (just for testing)

# Port your container listens on
app_port = 3000                        # Next.js=3000 | Django=8000 | Flask=5000

# Path that returns HTTP 200 when app is healthy
app_health_check_path = "/"            # or "/health" | "/api/ping"

# Set to true only if your Docker image is in a PRIVATE registry
docker_registry_auth     = false
docker_registry_server   = ""         # "https://index.docker.io/v1/" for Docker Hub
docker_registry_username = ""         # your registry username
docker_registry_password = ""         # your registry password or token

# ── Environment Variables ─────────────────────────────────────────────────────
# IDE: add ALL variables your app needs to run in production.
# These are stored encrypted in AWS SSM Parameter Store.
# Common patterns by stack:

app_env_vars = {
  # ── Universal ──────────────────────────────────────────────────────────────
  NODE_ENV = "production"              # for Node.js apps
  PORT     = "3000"                    # must match app_port above
  HOSTNAME = "0.0.0.0"               # bind to all interfaces (required in Docker)

  # ── Database (uncomment what applies) ─────────────────────────────────────
  # DATABASE_URL      = "postgresql://user:password@host:5432/dbname"
  # MONGODB_URI       = "mongodb+srv://user:pass@cluster.mongodb.net/db"
  # REDIS_URL         = "redis://default:password@host:6379"

  # ── Authentication ─────────────────────────────────────────────────────────
  # NEXTAUTH_URL      = "https://yourdomain.com"
  # NEXTAUTH_SECRET   = "generate-with: openssl rand -base64 32"
  # JWT_SECRET        = "your-jwt-secret"

  # ── Storage (S3 values auto-injected by Terraform if enable_s3 = true) ────
  # AWS_S3_BUCKET     = ""    ← filled automatically
  # AWS_S3_REGION     = ""    ← filled automatically

  # ── Email ──────────────────────────────────────────────────────────────────
  # SENDGRID_API_KEY  = "SG.xxxx"
  # SMTP_HOST         = "smtp.gmail.com"
  # SMTP_PORT         = "587"
  # SMTP_USER         = "you@gmail.com"
  # SMTP_PASS         = "your-app-password"

  # ── Payments ───────────────────────────────────────────────────────────────
  # STRIPE_SECRET_KEY         = "sk_live_xxxx"
  # STRIPE_PUBLISHABLE_KEY    = "pk_live_xxxx"
  # STRIPE_WEBHOOK_SECRET     = "whsec_xxxx"

  # ── External APIs ──────────────────────────────────────────────────────────
  # OPENAI_API_KEY    = "sk-xxxx"
  # GOOGLE_CLIENT_ID  = "xxxx.apps.googleusercontent.com"
  # GOOGLE_SECRET     = "xxxx"

  # ── App-specific (IDE: add project-specific vars here) ────────────────────
  # NEXT_PUBLIC_API_URL = "https://api.yourdomain.com"
  # APP_SECRET          = "xxxx"
}


# ── SECTION 4: Domain & SSL ───────────────────────────────────────────────────

domain_name   = "<YOUR_DOMAIN>"        # e.g. "proteinlab.com" — no https://, no www
certbot_email = "<YOUR_EMAIL>"         # e.g. "mahdi@gmail.com" — for SSL cert alerts


# ── SECTION 5: EC2 Server ─────────────────────────────────────────────────────

instance_type       = "t2.micro"       # FREE tier — 1 vCPU, 1GB RAM
ami_id              = "ami-0c02fb55956c7d316"  # Amazon Linux 2, us-east-1
root_volume_size_gb = 20               # GB — free tier allows up to 30GB
enable_elastic_ip   = true             # permanent IP — strongly recommended


# ── SECTION 6: S3 Storage ─────────────────────────────────────────────────────

enable_s3     = true                   # free: 5GB + 20k GET + 2k PUT/month
s3_versioning = true                   # keep file history (uses a bit more storage)
s3_lifecycle_days = 30                 # delete old versions after 30 days

# Domains allowed to access S3 from browser (CORS)
# IDE: replace with actual domain
s3_cors_allowed_origins = ["https://<YOUR_DOMAIN>", "https://www.<YOUR_DOMAIN>"]


# ── SECTION 7: CloudWatch Monitoring ─────────────────────────────────────────

enable_cloudwatch      = true
alarm_email            = "<YOUR_EMAIL>"  # where to send CPU/disk/down alerts
log_retention_days     = 14
cpu_alarm_threshold    = 80
memory_alarm_threshold = 85
disk_alarm_threshold   = 80


# ── SECTION 8: ECR (Optional) ────────────────────────────────────────────────

# Set to true to mirror your Docker Hub image to AWS ECR
# Recommended for production (faster, no rate limits)
enable_ecr    = false
ecr_repo_name = ""                     # e.g. "proteinlab-app"
